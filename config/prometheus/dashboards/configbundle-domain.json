{
  "title": "ConfigBundle Domain Controllers",
  "uid": "configbundle-domain",
  "tags": ["configbundle"],
  "schemaVersion": 39,
  "editable": true,
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "hide": 0,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "ServerConfigs failing reconcile",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "count(configbundle_serverconfig_reconcile_success == 0) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "BackupConfigs failing reconcile",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "count(configbundle_backupconfig_reconcile_success == 0) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Observed iDRAC settings (per server)",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "configbundle_serverconfig_status_idracsettings_info",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true, "Value": true, "__name__": true, "job": true,
              "instance": true, "endpoint": true, "namespace": true,
              "service": true, "pod": true, "container": true, "orb_id": true
            }
          }
        }
      ]
    },
    {
      "id": 4,
      "title": "etcd snapshot age (per cluster)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "time() - configbundle_backupconfig_status_etcd_last_snapshot_seconds",
          "legendFormat": "{{cluster}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    }
  ]
}
